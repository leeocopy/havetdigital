---
import { solution } from '../../data/landing.fr';
---

<section id="solution" class="py-16 md:py-24 relative bg-[var(--surface-2)]">
  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14 reveal">
      <span class="pill inline-flex mb-4">Notre solution</span>
      <h2 class="text-3xl md:text-4xl font-semibold font-sans tracking-tight mb-4">
        {solution.title}
      </h2>
      <p class="text-base md:text-lg text-[var(--text-muted)] max-w-3xl mx-auto leading-relaxed">
        {solution.paragraph}
      </p>
    </div>

    <!-- Feature chips bento grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-stretch max-w-5xl mx-auto">
      {solution.chips.map((chip, i) => (
        <div class={`h-full bg-[#f9f8fc] border border-[color:var(--border)] rounded-[var(--r-lg)] shadow-[var(--shadow-sm)] hover:-translate-y-[1px] hover:shadow-[var(--shadow-md)] transition-all duration-300 flex flex-col reveal text-left reveal-delay-${i + 1}`}>
          
          <!-- Illustration area -->
          <div class="m-2 rounded-[16px] border border-[color:var(--border)] bg-white min-h-[180px] flex items-center justify-center p-6 relative overflow-hidden">
            
            {i === 0 && (
              <svg width="100%" height="100%" viewBox="0 0 160 120" class="absolute inset-0 w-full h-full" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <!-- Grid background -->
                <path d="M0 60 h160 M80 0 v120" stroke="var(--border)" stroke-width="1" stroke-dasharray="2 4"/>
                <circle cx="80" cy="60" r="40" stroke="var(--border)" stroke-width="1" stroke-dasharray="2 4"/>
                <!-- Device -->
                <rect x="64" y="30" width="32" height="60" rx="6" fill="white" stroke="var(--text-muted)" stroke-width="1.5"/>
                <!-- Screen -->
                <rect x="68" y="36" width="24" height="42" rx="2" stroke="var(--brand)" stroke-width="1.5"/>
                <!-- Accents -->
                <circle cx="80" cy="84" r="1.5" fill="var(--brand-3)"/>
                <circle cx="72" cy="40" r="1.5" fill="var(--brand-3)"/>
                <circle cx="88" cy="40" r="1.5" fill="var(--brand)"/>
                <circle cx="80" cy="60" r="6" fill="white" stroke="var(--brand-3)" stroke-width="1.5"/>
              </svg>
            )}

            {i === 1 && (
              <svg width="100%" height="100%" viewBox="0 0 160 120" class="absolute inset-0 w-full h-full" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M20 60 h120" stroke="var(--border)" stroke-width="1.5" stroke-dasharray="4 4"/>
                <!-- Timeline nodes -->
                <circle cx="40" cy="60" r="8" fill="white" stroke="var(--text-muted)" stroke-width="1.5"/>
                <circle cx="120" cy="60" r="8" fill="white" stroke="var(--text-muted)" stroke-width="1.5"/>
                <!-- Center pop -->
                <rect x="65" y="45" width="30" height="30" rx="4" fill="white" stroke="var(--brand)" stroke-width="1.5"/>
                <!-- Flash / Fast -->
                <path d="M82 52 l-4 8 h6 l-2 8" stroke="var(--brand-3)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="65" cy="45" r="3" fill="var(--brand)"/>
                <circle cx="95" cy="75" r="3" fill="var(--brand-3)"/>
                <path d="M48 60 h17" stroke="var(--brand)" stroke-width="1.5"/>
              </svg>
            )}

            {i === 2 && (
              <svg width="100%" height="100%" viewBox="0 0 160 120" class="absolute inset-0 w-full h-full" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <!-- Coordinate lines -->
                <path d="M30 20 v80 M64 20 v80 M98 20 v80 M132 20 v80" stroke="var(--border)" stroke-width="1" stroke-dasharray="2 4"/>
                <!-- Line Chart Curve -->
                <path d="M30 80 Q 47 80, 64 50 T 98 70 T 132 30" stroke="var(--brand)" stroke-width="1.5" fill="none"/>
                <!-- Dots -->
                <circle cx="30" cy="80" r="3" fill="var(--text-muted)"/>
                <circle cx="64" cy="50" r="3" fill="var(--text-muted)"/>
                <circle cx="98" cy="70" r="3" fill="var(--text-muted)"/>
                <circle cx="132" cy="30" r="4" fill="white" stroke="var(--brand-3)" stroke-width="2"/>
                <circle cx="132" cy="30" r="1.5" fill="var(--brand)"/>
              </svg>
            )}

            {i === 3 && (
              <svg width="100%" height="100%" viewBox="0 0 160 120" class="absolute inset-0 w-full h-full" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M80 20 v80" stroke="var(--border)" stroke-width="1" stroke-dasharray="2 4"/>
                <path d="M40 60 h80" stroke="var(--border)" stroke-width="1" stroke-dasharray="2 4"/>
                <!-- Shields / Layers -->
                <rect x="50" y="40" width="30" height="40" rx="4" fill="white" stroke="var(--text-muted)" stroke-width="1.5"/>
                <rect x="65" y="50" width="45" height="30" rx="4" fill="white" stroke="var(--brand)" stroke-width="1.5"/>
                <!-- Linking -->
                <circle cx="50" cy="40" r="3" fill="white" stroke="var(--text-muted)" stroke-width="1.5"/>
                <circle cx="110" cy="50" r="3" fill="white" stroke="var(--brand)" stroke-width="1.5"/>
                <circle cx="65" cy="80" r="3" fill="var(--brand-3)"/>
                <path d="M85 65 h5" stroke="var(--brand-3)" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            )}

          </div>

          <!-- Text area -->
          <div class="px-6 py-5 pb-7">
            <h3 class="text-[1.05rem] font-semibold font-sans text-[var(--text)] mb-1.5 tracking-tight">{chip.label}</h3>
            <p class="text-[0.875rem] text-[var(--text-muted)] leading-relaxed">{chip.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
