---
import { options } from '../../data/landing.fr';

const itemIds = ['option-copywriting', 'option-rdv', 'option-automation'];
---

<section id="options" class="py-16 md:py-24 bg-[var(--surface-2)]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header Block -->
    <div class="flex flex-col items-start gap-4 max-w-3xl mb-16 md:mb-20 reveal">
      <div class="flex items-center gap-4">
        <span class="pill inline-flex">Sur-mesure</span>
        <span class="text-sm font-medium text-[var(--text-muted)]">Uniquement ce dont vous avez besoin</span>
      </div>
      <h2 class="text-3xl lg:text-5xl font-semibold font-sans tracking-tight m-0 leading-tight">
        {options.sectionTitle}
      </h2>
      <p class="text-base lg:text-lg text-[var(--text-muted)] leading-relaxed m-0 mt-2">
        {options.sectionSubtitle}
      </p>
    </div>

    <!-- Layout: Left Nav + Right Content -->
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 items-start relative">
      
      <!-- Left: Sticky Nav -->
      <aside class="hidden lg:block w-[240px] shrink-0 sticky top-32">
        <nav 
          class="flex flex-col space-y-3 relative before:absolute before:inset-y-0 before:left-0 before:w-[2px] before:bg-[color:var(--border)]" 
          aria-label="Menu des options"
        >
          {options.items.map((opt, i) => (
            <a 
              href={`#${itemIds[i]}`} 
              data-spy-link
              class="relative pl-6 py-2 text-lg text-[var(--text-muted)] hover:text-[var(--text)] transition-all duration-300 nav-link tracking-wide"
              aria-current={i === 0 ? "true" : "false"}
            >
              {opt.name}
            </a>
          ))}
        </nav>
      </aside>

      <!-- Right: Stacked Option Blocks -->
      <div class="flex-1 space-y-16 lg:space-y-24 w-full pb-16">
        {options.items.map((opt, i) => (
          <div 
            id={itemIds[i]} 
            data-spy-section
            class="option-block flex flex-col gap-6 md:gap-8 scroll-mt-32 w-full group"
          >
            <!-- A) Text OUTSIDE the media card -->
            <div class="flex flex-col items-start gap-3">
              <div class="flex flex-wrap items-baseline gap-4 md:gap-6">
                <h3 class="text-3xl md:text-4xl font-semibold font-sans m-0 flex items-center gap-3">
                  <span class="text-3xl" aria-hidden="true">{opt.icon}</span>
                  {opt.name}
                </h3>
                <span class="text-2xl md:text-3xl font-extrabold font-sans text-[var(--brand)]">
                  {opt.price}
                </span>
              </div>
              <p class="text-lg text-[var(--text-muted)] leading-relaxed max-w-3xl m-0">
                {opt.benefit}
              </p>
            </div>

            <!-- B) BIG MEDIA CARD on the right / below with NO background (embedded feel) -->
            <div class="media-card overflow-hidden min-h-[300px] md:min-h-[420px] lg:min-h-[460px] flex items-center justify-center relative transition-all duration-300 transform group-hover:-translate-y-1">
              <img 
                src={opt.media} 
                alt={`Mockup illustrative de ${opt.name}`}
                class="w-full h-full object-contain filter drop-shadow-md hover:scale-[1.02] transition-transform duration-500 max-h-[400px]"
                loading="lazy"
              />
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* Scroll-Spy nav styling */
  .nav-link[aria-current="true"] {
    color: var(--brand);
    font-weight: 600;
  }
  
  .nav-link[aria-current="true"]::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background-color: var(--brand);
    border-radius: 0 4px 4px 0;
    transition: all 0.3s ease;
  }

  /* Reveal animations */
  .option-block {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease-out, transform 0.5s ease-out;
  }
  
  .option-block.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .option-block {
      transition: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  function initOptionsScrollSpy() {
    const sections = document.querySelectorAll('[data-spy-section]');
    const navLinks = document.querySelectorAll('[data-spy-link]');

    if (!sections.length || !navLinks.length) return;

    // Detect section intersecting upper middle part of viewport
    const spyOptions = {
      rootMargin: '-20% 0px -50% 0px',
      threshold: 0
    };
    
    const spyObserver = new IntersectionObserver((entries) => {
      let activeFound = false;
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          activeFound = true;
          navLinks.forEach(link => {
            const isMatch = link.getAttribute('href') === `#${entry.target.id}`;
            link.setAttribute('aria-current', isMatch ? 'true' : 'false');
          });
        }
      });
    }, spyOptions);

    // Fade-in animation for blocks
    const entranceObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          entranceObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    sections.forEach(sec => {
      spyObserver.observe(sec);
      entranceObserver.observe(sec);
    });

    // Smooth scroll offset adjustment
    navLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        const targetId = link.getAttribute('href')?.substring(1);
        if (!targetId) return;
        
        const targetSection = document.getElementById(targetId);
        if (targetSection) {
          e.preventDefault();
          const headerOffset = 110; // Compensates for top sticky header
          const elementPosition = targetSection.getBoundingClientRect().top;
          const offsetPosition = elementPosition + window.scrollY - headerOffset;
    
          window.scrollTo({
            top: offsetPosition,
            behavior: 'smooth'
          });
        }
      });
    });
  }

  initOptionsScrollSpy();
</script>
