---
import { hero, brand } from '../../data/landing.fr';
import Button from '../ui/Button.astro';
---

<section id="hero" class="relative pt-28 pb-20 md:pt-40 md:pb-32 overflow-hidden">
  <!-- Gradient glow light mode -->
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[600px] opacity-10 pointer-events-none"
    aria-hidden="true"
  >
    <div
      class="w-full h-full rounded-full"
      style="background: radial-gradient(ellipse at center, var(--brand) 0%, transparent 60%);"
    ></div>
  </div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 text-center">
    <!-- Badge -->
    <div class="reveal">
      <span class="pill inline-flex mb-6">{hero.badge}</span>
    </div>

    <!-- H1 -->
    <h1
      class="reveal reveal-delay-1 text-4xl sm:text-5xl md:text-6xl font-semibold font-sans leading-tight tracking-tight mb-6"
    >
      {hero.title.split(',')[0]}
      <span class="text-[var(--brand)]">
        enfin rentable.
      </span>
    </h1>

    <!-- Subtitle -->
    <p
      class="reveal reveal-delay-2 text-base md:text-lg text-[var(--text-muted)] max-w-2xl mx-auto mb-8 leading-relaxed"
    >
      {hero.subtitle}
    </p>

    <!-- Trust bullets -->
    <div class="reveal reveal-delay-3 flex flex-wrap justify-center gap-3 mb-10">
      {hero.bullets.map((b) => (
        <span class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--text-muted)] bg-white px-4 py-2 rounded-full border border-[color:var(--border)]">
          <svg class="w-4 h-4 text-[var(--brand)] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          {b}
        </span>
      ))}
    </div>

    <!-- CTAs -->
    <div class="reveal reveal-delay-4 flex flex-col sm:flex-row items-center justify-center gap-4">
      <Button href={brand.primaryCta.href} variant="primary">
        {brand.primaryCta.label}
        <svg class="w-5 h-5 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </Button>
      <Button href={brand.secondaryCta.href} variant="secondary">
        {brand.secondaryCta.label}
      </Button>
    </div>
  </div>
</section>
