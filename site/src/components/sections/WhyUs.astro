---
import { whyUs } from '../../data/landing.fr';
---

<section id="pourquoi" class="py-16 md:py-24 relative">
  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14 reveal">
      <span class="pill inline-flex mb-4">Nos forces</span>
      <h2 class="text-3xl md:text-4xl font-semibold font-sans tracking-tight">
        {whyUs.sectionTitle}
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-6 mb-10">
      <!-- France -->
      <div class="bento-card p-8 reveal reveal-delay-1">
        <div class="flex items-center gap-3 mb-6">
          <span class="text-3xl">{whyUs.france.flag}</span>
          <h3 class="text-lg font-semibold font-sans">{whyUs.france.name}</h3>
        </div>
        <ul class="space-y-3">
          {whyUs.france.bullets.map((b) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[var(--brand)] mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-[var(--text-muted)] leading-relaxed">{b}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Morocco -->
      <div class="bento-card p-8 reveal reveal-delay-2">
        <div class="flex items-center gap-3 mb-6">
          <span class="text-3xl">{whyUs.morocco.flag}</span>
          <h3 class="text-lg font-semibold font-sans">{whyUs.morocco.name}</h3>
        </div>
        <ul class="space-y-3">
          {whyUs.morocco.bullets.map((b) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[var(--brand-2)] mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-[var(--text-muted)] leading-relaxed">{b}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Conclusion -->
    <div class="reveal reveal-delay-3 text-center">
      <p class="text-lg text-[var(--text-muted)] max-w-3xl mx-auto leading-relaxed italic">
        {whyUs.conclusion}
      </p>
    </div>
  </div>
</section>
