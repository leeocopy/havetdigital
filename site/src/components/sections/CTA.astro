---
import { audit } from '../../data/landing.fr';
import Button from '../ui/Button.astro';
---

<section id="audit" class="py-16 md:py-24 bg-[var(--surface-2)]">
  <div class="max-w-[1100px] mx-auto px-4 sm:px-6">
    
    <!-- CTA Banner Card -->
    <div class="cta-card relative overflow-hidden rounded-[28px] bg-white shadow-[0_8px_40px_rgba(15,23,42,0.10)] text-center px-6 sm:px-12 md:px-20 py-14 md:py-20 reveal">
      
      <!-- ===== Decorative Ribbons (left + right) ===== -->
      <!-- Left ribbon -->
      <div aria-hidden="true" class="ribbon ribbon-left absolute top-0 left-0 h-full w-72 md:w-80 pointer-events-none z-0">
        <svg viewBox="0 0 320 560" fill="none" preserveAspectRatio="xMinYMid slice" class="h-full w-full opacity-90">
          <path d="M-40 0 C60 80 120 240 80 400 C50 520 -20 560 -80 560 L-80 0 Z" fill="url(#ribbonGradLeft)"/>
          <defs>
            <linearGradient id="ribbonGradLeft" x1="0" y1="0" x2="0" y2="1" gradientUnits="objectBoundingBox">
              <stop offset="0%" stop-color="var(--brand)" stop-opacity="0.18"/>
              <stop offset="100%" stop-color="var(--brand-2, #52AFDA)" stop-opacity="0.10"/>
            </linearGradient>
          </defs>
        </svg>
      </div>

      <!-- Right ribbon -->
      <div aria-hidden="true" class="ribbon ribbon-right absolute top-0 right-0 h-full w-72 md:w-80 pointer-events-none z-0">
        <svg viewBox="0 0 320 560" fill="none" preserveAspectRatio="xMaxYMid slice" class="h-full w-full opacity-90">
          <path d="M360 0 C260 80 200 240 240 400 C270 520 340 560 400 560 L400 0 Z" fill="url(#ribbonGradRight)"/>
          <defs>
            <linearGradient id="ribbonGradRight" x1="0" y1="0" x2="0" y2="1" gradientUnits="objectBoundingBox">
              <stop offset="0%" stop-color="var(--brand-2, #52AFDA)" stop-opacity="0.15"/>
              <stop offset="100%" stop-color="var(--brand)" stop-opacity="0.10"/>
            </linearGradient>
          </defs>
        </svg>
      </div>

      <!-- ===== Decorative Envelope Icons (left + right) ===== -->
      <!-- Left icon: Calendar Check -->
      <div aria-hidden="true" class="envelope envelope-left absolute left-6 md:left-14 top-1/2 -translate-y-1/2 z-0 pointer-events-none hidden sm:block">
        <div class="shadow-lg rounded-xl" style="filter: drop-shadow(0 4px 16px rgba(92,72,177,0.18));">
          <svg width="72" height="72" viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="72" height="72" rx="14" fill="white" opacity="0.97"/>
            <rect width="72" height="72" rx="14" stroke="rgba(92,72,177,0.12)" stroke-width="1"/>
            <defs>
              <linearGradient id="calGrad" x1="14" y1="14" x2="58" y2="58" gradientUnits="userSpaceOnUse">
                <stop stop-color="#5C48B1"/>
                <stop offset="1" stop-color="#52AFDA"/>
              </linearGradient>
            </defs>
            <!-- Calendar body -->
            <rect x="15" y="20" width="42" height="36" rx="5" stroke="url(#calGrad)" stroke-width="2" fill="none"/>
            <!-- Header band -->
            <rect x="15" y="20" width="42" height="12" rx="5" fill="url(#calGrad)" opacity="0.12"/>
            <!-- Grid lines (days header) -->
            <line x1="15" y1="32" x2="57" y2="32" stroke="url(#calGrad)" stroke-width="1.5" opacity="0.4"/>
            <!-- Ring pegs -->
            <line x1="25" y1="15" x2="25" y2="25" stroke="url(#calGrad)" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="47" y1="15" x2="47" y2="25" stroke="url(#calGrad)" stroke-width="2.5" stroke-linecap="round"/>
            <!-- Checkmark inside calendar -->
            <path d="M26 44 L32 50 L46 38" stroke="url(#calGrad)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>
        </div>
      </div>

      <!-- Right icon: Clipboard Check -->
      <div aria-hidden="true" class="envelope envelope-right absolute right-6 md:right-14 top-1/2 -translate-y-1/2 z-0 pointer-events-none hidden sm:block">
        <div style="filter: drop-shadow(0 4px 16px rgba(82,175,218,0.18));">
          <svg width="72" height="72" viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="72" height="72" rx="14" fill="white" opacity="0.97"/>
            <rect width="72" height="72" rx="14" stroke="rgba(82,175,218,0.12)" stroke-width="1"/>
            <defs>
              <linearGradient id="clipGrad" x1="14" y1="14" x2="58" y2="58" gradientUnits="userSpaceOnUse">
                <stop stop-color="#52AFDA"/>
                <stop offset="1" stop-color="#5C48B1"/>
              </linearGradient>
            </defs>
            <!-- Clipboard body -->
            <rect x="18" y="20" width="36" height="38" rx="5" stroke="url(#clipGrad)" stroke-width="2" fill="none"/>
            <!-- Clipboard top clip -->
            <path d="M28 20 C28 16 44 16 44 20" stroke="url(#clipGrad)" stroke-width="2" fill="none" stroke-linecap="round"/>
            <rect x="28" y="17" width="16" height="6" rx="3" fill="white" stroke="url(#clipGrad)" stroke-width="1.5"/>
            <!-- Lines on clipboard -->
            <line x1="25" y1="34" x2="47" y2="34" stroke="url(#clipGrad)" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
            <line x1="25" y1="41" x2="40" y2="41" stroke="url(#clipGrad)" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
            <!-- Checkmark -->
            <path d="M24 48 L30 54 L48 40" stroke="url(#clipGrad)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>
        </div>
      </div>

      <!-- ===== Main Content (z-10, above decorations) ===== -->
      <div class="relative z-10 max-w-xl mx-auto">
        <span class="pill inline-flex mb-6">🎁 Gratuit</span>
        
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-semibold font-sans tracking-tight mb-5 leading-tight">
          {audit.title}
        </h2>
        
        <p class="text-base md:text-lg text-[var(--text-muted)] leading-relaxed mb-3 max-w-lg mx-auto">
          {audit.paragraph}
        </p>
        <p class="text-sm text-[var(--text-muted)] mb-10 italic">
          {audit.subtext}
        </p>

        <Button
          href={audit.ctaHref}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2"
        >
          {audit.ctaText}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </Button>

        <p class="mt-8 text-sm text-[var(--text-muted)]">
          Ou par email :
          <a href={`mailto:${audit.email}`} class="text-[var(--brand)] font-medium underline hover:no-underline ml-1">
            {audit.email}
          </a>
        </p>
      </div>
    </div>

  </div>
</section>

<style>
  .cta-card {
    /* Ensure the card clips ribbons cleanly */
    isolation: isolate;
  }

  .envelope-left {
    opacity: 0;
    transform: translateY(-50%) translateX(-8px);
    animation: floatEnvLeft 6s ease-in-out infinite;
  }

  .envelope-right {
    opacity: 0;
    transform: translateY(-50%) translateX(8px);
    animation: floatEnvRight 6s ease-in-out infinite;
  }

  /* Fade-in + gentle float once card is visible */
  .reveal.is-revealed .envelope-left,
  .cta-card .envelope-left {
    opacity: 1;
  }
  .cta-card .envelope-right {
    opacity: 1;
  }

  @keyframes floatEnvLeft {
    0%, 100% { transform: translateY(-50%) translateY(0px); }
    50%         { transform: translateY(-50%) translateY(-8px); }
  }

  @keyframes floatEnvRight {
    0%, 100% { transform: translateY(-50%) translateY(-4px); }
    50%         { transform: translateY(-50%) translateY(4px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .envelope-left,
    .envelope-right {
      animation: none;
    }
  }
</style>
