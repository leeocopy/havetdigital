---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Merci ! — HavetDigital × IAWeb">
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center max-w-md">
      <span class="text-6xl mb-6 block">🎉</span>
      <h1 class="text-3xl sm:text-4xl font-bold font-sans mb-4">
        Merci pour votre message !
      </h1>
      <p class="text-[var(--text-muted)] mb-8 leading-relaxed">
        Nous avons bien reçu votre demande et reviendrons vers vous dans les plus brefs délais.
      </p>
      <a href="/" class="btn-primary">
        Retour à l'accueil
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12h18m-6-6l6 6-6 6" />
        </svg>
      </a>
    </div>
  </div>
</BaseLayout>
